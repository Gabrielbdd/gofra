package config

import (
	"fmt"

	runtimev1 "__GOFRA_MODULE__/gen/__GOFRA_PROTO_PACKAGE__/runtime/v1"
)

// BindPublicConfig is starter-owned placeholder glue until the proto-driven
// runtime-config generator emits the binder from cfg.Public automatically.
func BindPublicConfig(cfg *Config) (*runtimev1.RuntimeConfig, error) {
	if cfg == nil {
		return nil, fmt.Errorf("config: nil *Config")
	}

	return &runtimev1.RuntimeConfig{
		AppName:    cfg.Public.AppName,
		APIBaseURL: cfg.Public.APIBaseURL,
		Auth: runtimev1.AuthConfig{
			Issuer:                 cfg.Public.Auth.Issuer,
			ClientID:               cfg.Public.Auth.ClientID,
			Scopes:                 append([]string(nil), cfg.Public.Auth.Scopes...),
			RedirectPath:           cfg.Public.Auth.RedirectPath,
			PostLogoutRedirectPath: cfg.Public.Auth.PostLogoutRedirectPath,
		},
	}, nil
}
