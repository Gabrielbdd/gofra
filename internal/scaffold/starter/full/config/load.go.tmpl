package config

import (
	runtimeconfig "__GOFRA_FRAMEWORK_MODULE__/runtime/config"

	flag "github.com/spf13/pflag"
)

// Load reads the application configuration using the framework's four-layer
// precedence: struct defaults, YAML file (gofra.yaml), environment variables,
// and CLI flags. Environment variables use GOFRA_ prefix with double-underscore
// for nesting (e.g. GOFRA_APP__PORT, GOFRA_PUBLIC__APP_NAME).
func Load(args []string) (*Config, error) {
	flags := flag.NewFlagSet("gofra", flag.ContinueOnError)
	flags.Int("app.port", 0, "HTTP server port")
	flags.String("app.name", "", "application name")
	flags.String("public.app_name", "", "public runtime app name")
	flags.String("public.api_base_url", "", "public runtime API base URL")
	flags.String("public.auth.issuer", "", "OIDC issuer URL")
	flags.String("public.auth.client_id", "", "OIDC browser client ID")
	flags.String("public.auth.redirect_path", "", "auth redirect path")
	flags.String("public.auth.post_logout_redirect_path", "", "post-logout redirect path")

	return runtimeconfig.Load(*Default(), args, runtimeconfig.WithFlags(flags))
}
