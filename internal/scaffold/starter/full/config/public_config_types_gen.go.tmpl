package config

// This file is starter-owned placeholder code that mirrors the shape of the
// future generated public config subtree until proto-driven generation is wired
// into the starter workflow.

type PublicConfig struct {
	AppName    string           `koanf:"app_name" yaml:"app_name"`
	APIBaseURL string           `koanf:"api_base_url" yaml:"api_base_url"`
	Auth       PublicAuthConfig `koanf:"auth" yaml:"auth"`
}

type PublicAuthConfig struct {
	Issuer                 string   `koanf:"issuer" yaml:"issuer"`
	ClientID               string   `koanf:"client_id" yaml:"client_id"`
	Scopes                 []string `koanf:"scopes" yaml:"scopes"`
	RedirectPath           string   `koanf:"redirect_path" yaml:"redirect_path"`
	PostLogoutRedirectPath string   `koanf:"post_logout_redirect_path" yaml:"post_logout_redirect_path"`
}
