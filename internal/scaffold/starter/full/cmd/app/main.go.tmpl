package main

import (
	"fmt"
	"log/slog"
	"net/http"
	"os"

	"__GOFRA_FRAMEWORK_MODULE__/runtime/config"
	"__GOFRA_MODULE__/config"
	"__GOFRA_MODULE__/web"
)

func main() {
	cfg, err := config.Load(os.Args[1:])
	if err != nil {
		slog.Error("failed to load config", "error", err)
		os.Exit(1)
	}

	mux := http.NewServeMux()
	mux.Handle(runtimeconfig.DefaultPath, config.PublicConfigHandler(cfg))
	mux.Handle("/", web.Handler())

	addr := fmt.Sprintf(":%d", cfg.App.Port)
	slog.Info("starting app", "app", cfg.App.Name, "addr", addr, "runtime_config_path", runtimeconfig.DefaultPath)

	if err := http.ListenAndServe(addr, mux); err != nil {
		slog.Error("server stopped", "error", err)
	}
}
