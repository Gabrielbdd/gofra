package main

import (
	"context"
	"fmt"
	"log/slog"
	"net/http"
	"os"

	"github.com/go-chi/chi/v5"

	runtimeconfig "__GOFRA_FRAMEWORK_MODULE__/runtime/config"
	runtimehealth "__GOFRA_FRAMEWORK_MODULE__/runtime/health"
	runtimeserve "__GOFRA_FRAMEWORK_MODULE__/runtime/serve"

	"__GOFRA_MODULE__/config"
	"__GOFRA_MODULE__/web"
)

func main() {
	cfg, err := config.Load(os.Args[1:])
	if err != nil {
		slog.Error("failed to load config", "error", err)
		os.Exit(1)
	}

	health := runtimehealth.New()

	// Health endpoints on the root mux, structurally outside app middleware.
	root := http.NewServeMux()
	root.Handle("/healthz/startup", health.StartupHandler())
	root.Handle("/healthz/live", health.LivenessHandler())
	root.Handle("/healthz/ready", health.ReadinessHandler())

	// App router — future middleware (CORS, recovery, etc.) mounts here.
	app := chi.NewRouter()
	app.Handle(runtimeconfig.DefaultPath, config.PublicConfigHandler(cfg))
	app.Handle("/*", web.Handler())

	root.Handle("/", app)

	addr := fmt.Sprintf(":%d", cfg.App.Port)
	slog.Info("starting app", "app", cfg.App.Name, "addr", addr)

	if err := runtimeserve.Serve(context.Background(), runtimeserve.Config{
		Handler: root,
		Addr:    addr,
		Health:  health,
	}); err != nil {
		slog.Error("server stopped with error", "error", err)
		os.Exit(1)
	}
}
