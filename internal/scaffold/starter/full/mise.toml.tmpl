[tools]
go = "1.25"

[tasks.generate]
description = "Generate config code (Go + TS) from proto"
run = """
GOWORK=off GOFLAGS=-mod=mod go run __GOFRA_FRAMEWORK_MODULE__/cmd/gofra generate config \
  -runtime __GOFRA_FRAMEWORK_MODULE__/runtime/config \
  -ts-out web/src/gen \
  proto/__GOFRA_PROTO_PACKAGE__/config/v1/config.proto
GOWORK=off go mod tidy
"""

[tasks.test]
description = "Run the application test suite"
depends = ["generate"]
run = "go test ./..."

[tasks."web:install"]
description = "Install frontend dependencies"
run = "cd web && npm install"
sources = ["web/package.json"]
outputs = ["web/node_modules/.package-lock.json"]

[tasks."web:dev"]
description = "Start the Vite dev server (run in a second terminal alongside `mise run dev`)"
depends = ["generate"]
run = "cd web && npm install && npm run dev"

[tasks."web:build"]
description = "Build the frontend into web/dist so the Go binary can embed it"
depends = ["generate"]
run = "cd web && npm install && npm run build"

[tasks.build]
description = "Build the application binary (embeds web/dist)"
depends = ["generate", "web:build"]
run = "go build -o bin/__GOFRA_APP_NAME__ ./cmd/app"

[tasks."gen:sql"]
description = "Generate Go code from SQL queries via sqlc"
run = "sqlc generate"
sources = ["db/queries/*.sql", "db/migrations/*.sql", "sqlc.yaml"]
outputs = ["db/sqlc/*.go"]

[tasks.dev]
description = "Generate and start the backend"
depends = ["generate"]
run = """
. ./scripts/load-env.sh
go run ./cmd/app
"""

[tasks.infra]
description = "Start local infrastructure (PostgreSQL + ZITADEL) and wait until ready"
run = """
. ./scripts/load-env.sh
sh ./scripts/compose.sh up -d
sh ./scripts/wait-for-postgres.sh
sh ./scripts/wait-for-zitadel.sh
"""

[tasks."infra:stop"]
description = "Stop infrastructure services"
run = """
. ./scripts/load-env.sh
sh ./scripts/compose.sh down --remove-orphans
"""

[tasks."infra:reset"]
description = "Stop infrastructure services and delete their data volumes"
run = """
. ./scripts/load-env.sh
sh ./scripts/compose.sh down --volumes --remove-orphans
"""

[tasks."infra:logs"]
description = "Tail infrastructure logs"
run = """
. ./scripts/load-env.sh
sh ./scripts/compose.sh logs -f
"""

[tasks.migrate]
description = "Run pending database migrations"
run = """
. ./scripts/load-env.sh
goose -dir db/migrations postgres "$DATABASE_URL" up
"""

[tasks."migrate:create"]
description = "Create a new migration file"
run = "goose -dir db/migrations create {{arg(i=0)}} sql"

[tasks."migrate:down"]
description = "Rollback the last migration"
run = """
. ./scripts/load-env.sh
goose -dir db/migrations postgres "$DATABASE_URL" down
"""

[tasks."migrate:status"]
description = "Show migration status"
run = """
. ./scripts/load-env.sh
goose -dir db/migrations postgres "$DATABASE_URL" status
"""

[tasks.seed]
description = "Seed the database with development data"
run = """
. ./scripts/load-env.sh
goose -dir db/seeds --no-versioning postgres "$DATABASE_URL" up
"""
